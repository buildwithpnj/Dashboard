# Database Config
DATABASE_URL=postgresql+asyncpg://personal_os:personal_os_dev@localhost:5432/personal_os

# Redis Config (Broker + Backend for Celery)
REDIS_URL=redis://localhost:6379/0

# Auth Secrets
JWT_SECRET=your_jwt_secret_must_be_long_and_secure
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Host and Port Configuration
API_HOST=127.0.0.1
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Anthropic API Config (Only real external dependency for Phase 8)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
