# Environment Config Variables Example - Production Environment
APP_NAME=Warborn Agent Platform Core
APP_ENV=production
PORT=8000
HOST=0.0.0.0

# Database URL (Production postgresql config ready)
DATABASE_URL=postgresql+asyncpg://postgres:securepassword@db:5432/warborn_production

# Provider configs
MODEL_PROVIDER=openai
MODEL_NAME=gpt-4o-mini
OPENAI_API_KEY=your-production-api-key-here
OPENAI_ENABLED=True

# Auth settings
AUTH_ENABLED=True
ADMIN_API_KEY=your-production-api-admin-secret-key
JWT_SECRET_KEY=production_jwt_secret_signing_key_32_bytes
DEFAULT_TENANT_ID=production_tenant

# Task queue settings
CELERY_ENABLED=True
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
