# Environment Config Variables Example - Staging Environment
APP_NAME=Warborn Agent Platform Core [STAGING]
APP_ENV=staging
PORT=8000
HOST=0.0.0.0

# Database URL
DATABASE_URL=sqlite+aiosqlite:///warborn_staging.db

# Provider configs
MODEL_PROVIDER=openai
MODEL_NAME=gpt-4o-mini
OPENAI_API_KEY=your-staging-api-key-here
OPENAI_ENABLED=True

# Auth settings
AUTH_ENABLED=True
ADMIN_API_KEY=warborn_staging_secret
JWT_SECRET_KEY=staging_jwt_secret_signing_key_32_bytes
DEFAULT_TENANT_ID=staging_tenant

# Task queue settings
CELERY_ENABLED=True
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
