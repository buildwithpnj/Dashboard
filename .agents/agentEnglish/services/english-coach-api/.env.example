# Application Config
APP_NAME="Warborn English Coach API"
APP_ENV="development"
API_V1_PREFIX="/v1"
PORT=8000
HOST="0.0.0.0"

# Model Provider Config
# Supported providers: mock, openai, gemini
MODEL_PROVIDER="mock"
MODEL_NAME="gpt-4o-mini"

# Provider State Switches
OPENAI_API_KEY=""
OPENAI_ENABLED=false
GEMINI_API_KEY=""

# Performance / Limit Configs
REQUEST_TIMEOUT_SECONDS=15
MAX_RETRIES=1
MAX_COMPLETION_TOKENS=180
MAX_RETRIEVED_MEMORIES=3
LOG_LEVEL="INFO"
